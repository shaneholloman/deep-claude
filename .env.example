# Copy to .env (gitignored). Most of this is written for you by `deep-claude pick`.

# --- OpenRouter (the default path) -----------------------------------------
# Your OpenRouter key. Alternatively, store it in macOS Keychain and omit this:
#   security add-generic-password -s deep-router -a openrouter -U -w
OPENROUTER_API_KEY=sk-or-...

# The curated set of OpenRouter model ids `deep-claude` exposes.
# `deep-claude pick` writes these three lines; edit by hand if you prefer.
# (Verify ids against https://openrouter.ai/models — they change over time.)
ROUTER_MODELS=anthropic/claude-opus-4.8,google/gemini-3.5-flash,deepseek/deepseek-v4-flash
ROUTER_ALIASES=opus=anthropic/claude-opus-4.8,gemini=google/gemini-3.5-flash,deepseek=deepseek/deepseek-v4-flash
ROUTER_DEFAULT_MODEL=gemini

# Optional: proxy port (default 8787), debug logging, strict allow-list.
# ROUTER_PORT=8787
# ROUTER_DEBUG=1
# ROUTER_STRICT=1

# --- Personal endpoints (second-tier: DeepSeek-direct, local, self-hosted) -
# Managed with `deep-claude endpoints add <name> <base-url> [KEY_ENV_VAR]`.
# Format: name|base-url|KEY_ENV_VAR  (comma-separated). Key comes from the
# named environment variable (shell or this file).
# DEEP_ENDPOINTS="deepseek|https://api.deepseek.com/anthropic|DEEPSEEK_API_KEY"
# DEEPSEEK_API_KEY=sk-...

# Optional: override the Claude executable.
# CLAUDE_BIN=claude
