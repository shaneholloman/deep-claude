# Copy to .env and set your DeepSeek API key.
# Alternatively, store the key in macOS Keychain and skip this file entirely:
#   security add-generic-password -s deep-claude -a deepseek -U -w
DEEPSEEK_API_KEY=sk-...

# Optional: override the Claude executable.
# CLAUDE_BIN=claude

# Optional: override the cco executable (used by deep-cco).
# CCO_BIN=cco

# --- deep-router (OpenRouter passthrough) ----------------------------------
# Your OpenRouter key. Alternatively, store it in macOS Keychain and omit this:
#   security add-generic-password -s deep-router -a openrouter -U -w
OPENROUTER_API_KEY=sk-or-...

# The curated set of OpenRouter model ids deep-router will expose.
# (Verify ids against https://openrouter.ai/models — they change over time.)
ROUTER_MODELS=anthropic/claude-opus-4.8,google/gemini-3.5-flash,deepseek/deepseek-v4-flash

# Friendly aliases you can pass to `deep-claude --open-router --model NAME`.
ROUTER_ALIASES=opus=anthropic/claude-opus-4.8,gemini=google/gemini-3.5-flash,deepseek=deepseek/deepseek-v4-flash

# Model used when --model is omitted (an alias above, or a full model id).
ROUTER_DEFAULT_MODEL=gemini

# Optional: proxy port (default 8787) and debug logging.
# ROUTER_PORT=8787
# ROUTER_DEBUG=1
# Optional: reject any model not in ROUTER_MODELS/ROUTER_ALIASES.
# ROUTER_STRICT=1
