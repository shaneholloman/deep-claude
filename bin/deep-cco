#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so the script works when installed via symlink (e.g. ~/.local/bin/deep-cco).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_DIR/.env"
STATE_DIR="$PROJECT_DIR/.deep-claude-home"

usage() {
  cat <<'EOF'
Usage: deep-cco [--model pro|flash|MODEL] [cco/claude args...]

Runs Claude Code against DeepSeek's Anthropic-compatible endpoint inside
nikvdp/cco's sandbox. Shares state with deep-claude (same .env, same
state dir, same model aliases), so DeepSeek session history is consistent
whether you launch sandboxed or unsandboxed.

Defaults:
  --model pro     deepseek-v4-pro

Aliases:
  --model pro     deepseek-v4-pro
  --model flash   deepseek-v4-flash

Environment:
  DEEPSEEK_API_KEY may be supplied via (in precedence order):
    1. exported in the shell
    2. .env next to this repo
    3. macOS Keychain item: service "deep-claude", account "deepseek"
       Add with:
         security add-generic-password -s deep-claude -a deepseek -U -w
  CCO_BIN may be set to override the cco executable (default: cco).

Requires nikvdp/cco: https://github.com/nikvdp/cco
EOF
}

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

# Treat the .env.example placeholder as unset, so a stale .env can't shadow
# a real key in Keychain or shell env.
if [[ "${DEEPSEEK_API_KEY:-}" == "sk-..." ]]; then
  unset DEEPSEEK_API_KEY
fi

# Fall back to macOS Keychain when DEEPSEEK_API_KEY isn't set via env or .env.
if [[ -z "${DEEPSEEK_API_KEY:-}" ]] && command -v security >/dev/null 2>&1; then
  if keychain_key="$(security find-generic-password -s deep-claude -a deepseek -w 2>/dev/null)"; then
    export DEEPSEEK_API_KEY="$keychain_key"
  fi
fi

model="deepseek-v4-pro"
passthrough=()

while (($#)); do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --model)
      if (($# < 2)); then
        echo "deep-cco: --model requires a value: pro, flash, or a full model name" >&2
        exit 2
      fi
      case "$2" in
        pro) model="deepseek-v4-pro" ;;
        flash) model="deepseek-v4-flash" ;;
        *) model="$2" ;;
      esac
      shift 2
      ;;
    --model=*)
      value="${1#--model=}"
      case "$value" in
        pro) model="deepseek-v4-pro" ;;
        flash) model="deepseek-v4-flash" ;;
        *) model="$value" ;;
      esac
      shift
      ;;
    *)
      passthrough+=("$1")
      shift
      ;;
  esac
done

api_key="${DEEPSEEK_API_KEY:-}"
if [[ -z "$api_key" ]]; then
  echo "deep-cco: missing DEEPSEEK_API_KEY." >&2
  echo "  Set it in the shell, in $ENV_FILE, or store it in macOS Keychain:" >&2
  echo "    security add-generic-password -s deep-claude -a deepseek -U -w" >&2
  exit 1
fi

cco_bin="${CCO_BIN:-cco}"
if ! cco_resolved="$(command -v "$cco_bin")"; then
  echo "deep-cco: '$cco_bin' is not on PATH. Install from https://github.com/nikvdp/cco" >&2
  exit 1
fi

# Resolve cco's symlinks ourselves: cco infers its installation dir from
# $HOME and from $(dirname "${BASH_SOURCE[0]}"), and we're about to redirect
# $HOME below. Without this, cco invoked via a ~/.local/bin/cco symlink fails
# to find its lib/ directory.
while [ -L "$cco_resolved" ]; do
  cco_dir="$(cd -P "$(dirname "$cco_resolved")" >/dev/null 2>&1 && pwd)"
  cco_resolved="$(readlink "$cco_resolved")"
  [[ "$cco_resolved" != /* ]] && cco_resolved="$cco_dir/$cco_resolved"
done

mkdir -p "$STATE_DIR/home" "$STATE_DIR/config" "$STATE_DIR/cache" "$STATE_DIR/data" "$STATE_DIR/state"

export HOME="$STATE_DIR/home"
export XDG_CONFIG_HOME="$STATE_DIR/config"
export XDG_CACHE_HOME="$STATE_DIR/cache"
export XDG_DATA_HOME="$STATE_DIR/data"
export XDG_STATE_HOME="$STATE_DIR/state"

export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="$api_key"
export ANTHROPIC_API_KEY="$api_key"
export ANTHROPIC_MODEL="$model"

if ((${#passthrough[@]})); then
  exec "$cco_resolved" --model "$model" "${passthrough[@]}"
else
  exec "$cco_resolved" --model "$model"
fi
