#!/usr/bin/env node
'use strict';

// deep-claude-pick — a full-screen interactive picker for choosing which
// OpenRouter models to expose. No dependencies.
//
// Env (set by the `deep-claude pick` wrapper):
//   OPENROUTER_API_KEY    required — used to fetch the model catalog.
//   DEEP_CLAUDE_ENV_FILE  the .env file to write ROUTER_* into.
//   OPENROUTER_BASE_URL   optional upstream root (default https://openrouter.ai/api).
//
// Stages: (1) multi-select models with live search, (2) pick the default.
// Aliases are auto-derived from each model id (editable later via
// `deep-claude models add <id> <alias>`). Writes ROUTER_MODELS / ROUTER_ALIASES
// / ROUTER_DEFAULT_MODEL.

const fs = require('fs');

const API_KEY = process.env.OPENROUTER_API_KEY || '';
const ENV_FILE = process.env.DEEP_CLAUDE_ENV_FILE || '.env';
const BASE = (process.env.OPENROUTER_BASE_URL || 'https://openrouter.ai/api').replace(/\/+$/, '');

const out = process.stdout;
const C = {
  reset: '\x1b[0m', bold: '\x1b[1m', dim: '\x1b[2m', inv: '\x1b[7m',
  green: '\x1b[32m', cyan: '\x1b[36m', yellow: '\x1b[33m', mag: '\x1b[35m',
  red: '\x1b[31m', gray: '\x1b[90m',
};

function fail(msg) {
  out.write(`\n${C.red}deep-claude pick: ${msg}${C.reset}\n`);
  process.exit(1);
}

// ---- .env upsert -----------------------------------------------------------
function envSet(pairs) {
  let lines = [];
  if (fs.existsSync(ENV_FILE)) lines = fs.readFileSync(ENV_FILE, 'utf8').split('\n');
  for (const [key, value] of Object.entries(pairs)) {
    let found = false;
    lines = lines.map((l) => {
      if (l.startsWith(key + '=')) { found = true; return `${key}=${value}`; }
      return l;
    });
    if (!found) {
      if (lines.length && lines[lines.length - 1] === '') lines.splice(lines.length - 1, 0, `${key}=${value}`);
      else lines.push(`${key}=${value}`);
    }
  }
  fs.writeFileSync(ENV_FILE, lines.join('\n'));
}

function priceM(p) {
  const n = parseFloat(p) * 1e6;
  if (!isFinite(n) || n === 0) return 'free';
  return '$' + (n >= 1 ? n.toFixed(n % 1 ? 2 : 0) : n.toFixed(2));
}
function ctxShort(n) {
  if (!n) return '?';
  if (n >= 1e6) return (n / 1e6).toFixed(n % 1e6 ? 1 : 0) + 'M';
  if (n >= 1e3) return Math.round(n / 1e3) + 'K';
  return String(n);
}
function alias(id) {
  return id.split('/').pop().replace(/[^a-zA-Z0-9._-]/g, '').toLowerCase();
}

// ---- TUI core --------------------------------------------------------------
function setup() {
  out.write('\x1b[?1049h\x1b[?25l'); // alt screen, hide cursor
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  process.stdin.resume();
}
function teardown() {
  out.write('\x1b[?25h\x1b[?1049l'); // show cursor, leave alt screen
  if (process.stdin.isTTY) process.stdin.setRawMode(false);
  process.stdin.pause();
}

// Generic interactive list. opts: { title, rows:[{id,cells}], multi, footer }
// Returns a Promise resolving to an array of selected ids (or null if cancelled).
function runList({ title, rows, multi, preselect }) {
  return new Promise((resolve) => {
    let query = '';
    let cursor = 0;
    let top = 0;
    const selected = new Set(preselect || []);

    const filtered = () => {
      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      if (!terms.length) return rows;
      return rows.filter((r) => terms.every((t) => r.hay.includes(t)));
    };

    const render = () => {
      const rowsArr = filtered();
      const H = (process.stdout.rows || 24);
      const W = (process.stdout.columns || 100);
      const listH = Math.max(3, H - 6);
      if (cursor >= rowsArr.length) cursor = Math.max(0, rowsArr.length - 1);
      if (cursor < top) top = cursor;
      if (cursor >= top + listH) top = cursor - listH + 1;

      let s = '\x1b[H\x1b[2J';
      s += `${C.bold}${C.cyan}  ${title}${C.reset}\n`;
      s += `${C.gray}  ${rowsArr.length}/${rows.length} models` +
        (multi ? `  ·  ${C.green}${selected.size} selected${C.gray}` : '') +
        `${C.reset}\n`;
      s += `${C.gray}  search: ${C.reset}${query}${C.gray}▏${C.reset}\n\n`;

      const view = rowsArr.slice(top, top + listH);
      for (let i = 0; i < view.length; i++) {
        const r = view[i];
        const isCur = top + i === cursor;
        const box = multi ? (selected.has(r.id) ? `${C.green}◉${C.reset}` : `${C.gray}◯${C.reset}`) : ' ';
        let line = `${box} ${r.label}`;
        if (line.replace(/\x1b\[[0-9;]*m/g, '').length > W - 4) {
          // crude truncate on visible length
        }
        s += isCur ? `${C.inv}> ${line} ${C.reset}\n` : `  ${line}\n`;
      }
      for (let i = view.length; i < listH; i++) s += '\n';

      s += `\n${C.gray}  ↑/↓ move · ` +
        (multi ? 'space select · ' : '') +
        `type to search · ↵ ${multi ? 'confirm' : 'choose'} · esc cancel${C.reset}`;
      out.write(s);
    };

    // A single data chunk may carry several keystrokes (fast typing, paste, or
    // a terminal multiplexer batching input). Walk the buffer key by key,
    // recognizing CSI escape sequences for the arrows.
    const onKey = (buf) => {
      const s = buf.toString();
      let i = 0;
      let dirty = false;
      while (i < s.length) {
        let k;
        if (s[i] === '\x1b' && s[i + 1] === '[') { k = s.slice(i, i + 3); i += 3; }
        else { k = s[i]; i += 1; }
        const rowsArr = filtered();
        if (k === '\x03' || k === '\x1b') { cleanup(); return resolve(null); } // ctrl-c / esc
        if (k === '\r' || k === '\n') {
          cleanup();
          if (multi) return resolve([...selected]);
          return resolve(rowsArr[cursor] ? [rowsArr[cursor].id] : []);
        }
        if (k === '\x1b[A' || k === '\x10') { cursor = Math.max(0, cursor - 1); dirty = true; continue; }
        if (k === '\x1b[B' || k === '\x0e') { cursor = Math.min(rowsArr.length - 1, cursor + 1); dirty = true; continue; }
        if (k === ' ' && multi) {
          const r = rowsArr[cursor];
          if (r) { selected.has(r.id) ? selected.delete(r.id) : selected.add(r.id); cursor = Math.min(rowsArr.length - 1, cursor + 1); }
          dirty = true; continue;
        }
        if (k === '\x7f' || k === '\b') { query = query.slice(0, -1); cursor = 0; top = 0; dirty = true; continue; }
        if (k.length === 1 && k >= ' ' && k <= '~') { query += k; cursor = 0; top = 0; dirty = true; continue; }
      }
      if (dirty) render();
    };

    const cleanup = () => process.stdin.removeListener('data', onKey);
    process.stdin.on('data', onKey);
    render();
  });
}

// ---- main ------------------------------------------------------------------
async function main() {
  if (!API_KEY) fail('OPENROUTER_API_KEY is not set.');

  out.write('Fetching OpenRouter models…\r');
  let models;
  try {
    const r = await fetch(`${BASE}/v1/models`, { headers: { authorization: `Bearer ${API_KEY}` } });
    if (!r.ok) fail(`could not fetch models (HTTP ${r.status}).`);
    models = (await r.json()).data;
  } catch (e) {
    fail('could not reach OpenRouter: ' + e.message);
  }
  if (!Array.isArray(models) || !models.length) fail('no models returned.');

  models.sort((a, b) => a.id.localeCompare(b.id));

  // Pre-select whatever is already curated.
  let preEnv = '';
  try { if (fs.existsSync(ENV_FILE)) preEnv = fs.readFileSync(ENV_FILE, 'utf8'); } catch {}
  const preMatch = (preEnv.match(/^ROUTER_MODELS=(.*)$/m) || [])[1] || '';
  const preselect = preMatch.split(',').map((s) => s.trim()).filter(Boolean);

  const idW = Math.min(46, Math.max(...models.map((m) => m.id.length)));
  const rows = models.map((m) => {
    const id = m.id;
    const ctx = ctxShort(m.context_length).padStart(5);
    const price = `${priceM(m.pricing && m.pricing.prompt)}/${priceM(m.pricing && m.pricing.completion)}`.padEnd(14);
    const name = (m.name || '').slice(0, 40);
    const label =
      `${C.bold}${id.padEnd(idW)}${C.reset} ` +
      `${C.yellow}${ctx}${C.reset} ` +
      `${C.gray}${price}${C.reset} ` +
      `${C.dim}${name}${C.reset}`;
    return { id, label, hay: (id + ' ' + name).toLowerCase() };
  });

  setup();
  process.on('exit', teardown);

  const chosen = await runList({
    title: 'Select models to expose  (these appear in Claude Code’s /model picker)',
    rows, multi: true, preselect,
  });
  if (chosen === null || chosen.length === 0) { teardown(); out.write('No changes made.\n'); process.exit(0); }

  // Pick a default among the chosen.
  const chosenRows = rows.filter((r) => chosen.includes(r.id));
  const def = await runList({
    title: 'Pick the default model  (used when --model is omitted)',
    rows: chosenRows, multi: false,
  });

  teardown();

  // Auto-alias, uniquified.
  const aliases = [];
  const used = new Set();
  for (const id of chosen) {
    let a = alias(id);
    let n = a;
    let i = 2;
    while (used.has(n)) n = `${a}-${i++}`;
    used.add(n);
    aliases.push(`${n}=${id}`);
  }
  const defModel = def && def[0] ? def[0] : chosen[0];
  const defAlias = (aliases.find((p) => p.endsWith('=' + defModel)) || '=').split('=')[0] || defModel;

  envSet({
    ROUTER_MODELS: chosen.join(','),
    ROUTER_ALIASES: aliases.join(','),
    ROUTER_DEFAULT_MODEL: defAlias,
  });

  out.write(`\n${C.green}✓${C.reset} Saved ${C.bold}${chosen.length}${C.reset} models to ${C.cyan}${ENV_FILE}${C.reset}\n\n`);
  for (const p of aliases) {
    const [al, id] = p.split('=');
    const mark = id === defModel ? `${C.yellow} (default)${C.reset}` : '';
    out.write(`  ${C.green}${al.padEnd(18)}${C.reset}${C.gray}→${C.reset} ${id}${mark}\n`);
  }
  out.write(`\nRun:  ${C.bold}deep-claude --model ${defAlias}${C.reset}\n`);
  process.exit(0);
}

main().catch((e) => { teardown(); fail(e && e.stack ? e.stack : String(e)); });
